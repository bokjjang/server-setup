#===============================================================================
# gpakosz/.tmux 개인화 설정
# 이 파일은 ~/.tmux.conf (gpakosz) 에서 자동으로 source 됩니다.
#===============================================================================

#---------------------------------------
# 일반
#---------------------------------------
# 마우스 지원 (패널 클릭 이동, 스크롤, 드래그 리사이즈)
set -g mouse on

# 히스토리 버퍼 크기
set -g history-limit 10000

# 인덱스 1부터 시작 (0은 키보드 왼쪽 끝이라 불편)
set -g base-index 1
setw -g pane-base-index 1

# 윈도우 번호 자동 재정렬
set -g renumber-windows on

# ESC 딜레이 제거 (vim 사용 시 필수)
set -sg escape-time 0

#---------------------------------------
# 상태바
#---------------------------------------
# 상태바 상단으로 이동
set -g status-position top

#---------------------------------------
# 256 컬러 + True Color
#---------------------------------------
set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",*256col*:Tc"

# Powerline 화살표 구분자
tmux_conf_theme_left_separator_main='\uE0B0'
tmux_conf_theme_left_separator_sub='\uE0B1'
tmux_conf_theme_right_separator_main='\uE0B2'
tmux_conf_theme_right_separator_sub='\uE0B3'

#---------------------------------------
# 키 바인딩
#---------------------------------------
# 패널 분할 (직관적인 키)
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"

# 새 윈도우를 현재 경로에서 열기
bind c new-window -c "#{pane_current_path}"

# 패널 이동: prefix + hjkl (기본)
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# 패널 이동: Ctrl + hjkl (vim-tmux-navigator 연동)
# vim 안에서는 vim 분할창 이동, vim 바깥에서는 tmux 패널 이동
# vim ↔ tmux 패널 경계도 자유롭게 넘나든다
is_vim="ps -o state= -o comm= -t '#{pane_tty}' | grep -iqE '^[^TXZ ]+ +(\\S+\\/)?g?(view|n?vim?x?)(diff)?$'"
bind -n C-h if-shell "$is_vim" "send-keys C-h" "select-pane -L"
bind -n C-j if-shell "$is_vim" "send-keys C-j" "select-pane -D"
bind -n C-k if-shell "$is_vim" "send-keys C-k" "select-pane -U"
bind -n C-l if-shell "$is_vim" "send-keys C-l" "select-pane -R"

# 패널 리사이즈 (prefix + 대문자, 반복 가능)
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# prefix + y 로 Claude Code 팝업 토글
bind -r y run-shell '\
  SESSION="claude-$(echo #{pane_current_path} | md5sum | cut -c1-8)"; \
  tmux has-session -t "$SESSION" 2>/dev/null || \
  tmux new-session -d -s "$SESSION" -c "#{pane_current_path}" "claude --dangerously-skip-permissions"; \
  tmux display-popup -w80% -h80% -E "tmux attach -t $SESSION"'

# 설정 리로드
bind r source-file ~/.tmux.conf \; display "Config reloaded!"

#---------------------------------------
# 상태바 색상 커스터마이징 (필요 시 주석 해제)
#---------------------------------------
# gpakosz 테마 색상 변경
# set -g @theme_colour_1 default    # 기본 배경
# set -g @theme_colour_2 colour238  # 비활성 탭
# set -g @theme_colour_3 colour246  # 비활성 텍스트
# set -g @theme_colour_4 colour32   # 활성 탭 (파란색)

#---------------------------------------
# 클립보드 (로컬 환경용, SSH에서는 동작 안 할 수 있음)
#---------------------------------------
# bind -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "xclip -selection clipboard"


